{
    "buildCommand": "npm run build",
    "outputDirectory": "dist/AlgoArena-Master/browser",
    "rewrites": [
        { "source": "/generate", "destination": "/api/generate" },
        { "source": "/create-session", "destination": "/api/create-session" },
        { "source": "/get-sessions", "destination": "/api/get-sessions" },
        { "source": "/join-session", "destination": "/api/join-session" },
        { "source": "/submit-exam", "destination": "/api/submit-exam" },
        { "source": "/get-submissions", "destination": "/api/get-submissions" },
        { "source": "/update-score", "destination": "/api/update-score" },
        { "source": "/terminate-session", "destination": "/api/terminate-session" },
        { "source": "/(.*)", "destination": "/index.html" }
    ]
}